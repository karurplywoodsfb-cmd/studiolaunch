+            {btnNext('Continue', () => setStep(2))}
+          </div>
+        </div>
+      )}
+
+      {step === 2 && (
+        <div>
+          <h3 style={{fontFamily:'Georgia,serif',fontSize:'1.75rem',fontWeight:300,color:'#F5F0E8',marginBottom:'0.5rem'}}>Project scope?</h3>
